{
    "name": "guardianmesh-server",
    "version": "0.1.0",
    "description": "Self-hosted Family Guardian / GuardianMesh server",
    "type": "module",
    "private": true,
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "format": "prettier --write 'src/**/*.js'"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/formbody": "^8.0.2",
        "@fastify/multipart": "^9.4.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^9.1.3",
        "@fastify/websocket": "^11.2.0",
        "argon2": "^0.40.3",
        "better-sqlite3": "^11.3.0",
        "dotenv": "^16.4.5",
        "fastify": "^5.8.5",
        "firebase-admin": "^13.10.0",
        "qrcode": "^1.5.4",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "vitest": "^3.2.4"
    },
    "overrides": {
        "fast-uri": "^3.1.2",
        "@tootallnate/once": "^3.0.1"
    }
}
