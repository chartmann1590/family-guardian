# Copy to .env for local dev. Docker reads from docker-compose.yml instead.

# HTTP bind address + port
HOST=0.0.0.0
PORT=8080

# SQLite file. Outside Docker the default is server/data/guardian.db.
# DATABASE_PATH=/data/guardian.db

# REQUIRED in production. Any non-empty value works for dev.
SESSION_SECRET=change-me-in-production-please

# pino levels: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Set to "production" to (a) require SESSION_SECRET to be non-default,
# (b) mark the session cookie Secure (HTTPS only).
# NODE_ENV=production

# Push notifications via Firebase Cloud Messaging (optional).
# When unset, the server logs "FCM disabled" and all WS features still work.
# FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
